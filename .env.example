# Copy this file to ".env" and fill in your Supabase project values.
# These are exposed to the browser (Vite "VITE_" prefix) — that is expected.
# Security is enforced by Supabase Row Level Security + Storage policies, not by
# hiding these values. The anon key is meant to be public.
#
# Leave these blank to run the app in demo-only mode (no backend required).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
